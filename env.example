# =============================================================================
# Firewalla → Axiom Pipeline Configuration
#
# Copy this to .env and fill in your values:
#   cp env.example .env
#
# NEVER commit .env to git — it contains your API token.
# =============================================================================

# Axiom dataset for DNS/conn/ACL log events
AXIOM_DATASET=firewalla

# Axiom dataset for device IP-to-name lookup table
AXIOM_LOOKUP_DATASET=firewalla-devices

# Axiom API token (Settings → API Tokens → New Token → Ingest permission)
# Starts with xaat-
AXIOM_API_TOKEN=xaat-PASTE-YOUR-TOKEN-HERE

# --- Grafana Cloud Loki (direct push; optional) ------------------------------
# The Loki output ships the same events DIRECTLY to Grafana Cloud Loki (no LAN
# relay). Leave blank to disable that output (Axiom is unaffected).
# Host = the Loki push host (no scheme, no path), e.g. logs-prod-042.grafana.net
# User = the Grafana Cloud Loki instance/user ID (numeric)
# Token = a Grafana Cloud access-policy token with logs:write (glc_...)
GRAFANA_CLOUD_LOGS_HOST=logs-prod-XXX.grafana.net
GRAFANA_CLOUD_LOGS_USER=000000
GRAFANA_CLOUD_LOGS_TOKEN=glc-PASTE-YOUR-TOKEN-HERE
